{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    // Performance and Best Practices
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "prefer-const": "warn",
    
    // React Specific
    "react/no-unescaped-entities": "off",
    "react-hooks/exhaustive-deps": "warn",
    "react/display-name": "off",
    
    // Code Quality
    "no-var": "warn",
    "no-console": "warn",
    "no-debugger": "warn",
    
    // Import Organization
    "import/order": [
      "warn",
      {
        "groups": [
          "builtin",
          "external",
          "internal",
          "parent",
          "sibling",
          "index"
        ],
        "newlines-between": "always"
      }
    ]
  },
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "prefer-const": "error"
      }
    }
  ]
}